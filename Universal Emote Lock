-- [[ CONFIGURAÇÃO DA GUI - APENAS ÍCONE ]] --
local ScreenGui = Instance.new("ScreenGui")
local FreezeButton = Instance.new("ImageButton")
local UICorner = Instance.new("UICorner")

-- Seus IDs
local ID_MOVENDO = "rbxassetid://110718214871194"
local ID_PARALISADO = "rbxassetid://98071581527161"

ScreenGui.Name = "FreezeEmote_IconOnly"
ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

-- Configuração do Botão (Sem bordas, fundo transparente)
FreezeButton.Name = "FreezeButton"
FreezeButton.Parent = ScreenGui
FreezeButton.BackgroundTransparency = 1 -- Fundo totalmente transparente
FreezeButton.BorderSizePixel = 0 -- Remove qualquer borda residual
FreezeButton.Position = UDim2.new(0.85, 0, 0.70, 0)
FreezeButton.Size = UDim2.new(0, 70, 0, 70)
FreezeButton.Image = ID_MOVENDO
FreezeButton.ScaleType = Enum.ScaleType.Fit

-- [[ SISTEMA DE ARRASTAR ]] --
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    FreezeButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

FreezeButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = FreezeButton.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
        update(input)
    end
end)

-- [[ LÓGICA DE ESTÁTUA AMBULANTE REAL ]] --
local isPaused = false

FreezeButton.MouseButton1Click:Connect(function()
    local character = game.Players.LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    local animateScript = character:FindFirstChild("Animate")
    if not humanoid then return end

    isPaused = not isPaused

    if isPaused then
        -- MODO: ESTÁTUA
        FreezeButton.Image = ID_PARALISADO

        if animateScript then
            animateScript.Disabled = true
        end

        local playingTracks = humanoid:GetPlayingAnimationTracks()
        for _, track in ipairs(playingTracks) do
            track:AdjustSpeed(0)
        end
    else
        -- MODO: NORMAL
        FreezeButton.Image = ID_MOVENDO

        if animateScript then
            animateScript.Disabled = false
        end

        local playingTracks = humanoid:GetPlayingAnimationTracks()
        for _, track in ipairs(playingTracks) do
            track:AdjustSpeed(1)
        end
    end
end)

print("Interface Minimalista Ativada: Apenas o ícone está visível.")